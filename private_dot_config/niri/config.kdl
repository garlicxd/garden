// This config is in the KDL format: https://kdl.dev
// "/-" comments out the following node.
// Check the wiki for a full description:
// https://niri-wm.github.io/niri/Configuration:-Introduction

// ────────────── Standalone Settings ──────────────

// Ask clients to omit CSD so niri draws borders/rings around windows.
prefer-no-csd

// Screenshot save path (strftime-formatted).
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// Cursor theme.
cursor {

}

// Debug: honor activation tokens even with invalid serials.
debug {
    honor-xdg-activation-with-invalid-serial
}

// Hotkey overlay (set skip-at-startup to suppress the initial pop-up).
hotkey-overlay {
    // skip-at-startup
}

// ────────────── Included Config Modules ──────────────

include "env.kdl"
include "input.kdl"
include "layout.kdl"
include "effects.kdl"
include "gestures.kdl"
include "animation.kdl"
include "autostart.kdl"
include "keybinds.kdl"
include "rules.kdl"
include "noctalia.kdl"
include "display.kdl"
