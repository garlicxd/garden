// ────────────── Input Configuration ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Input

input {
    keyboard {
        xkb {
            // layout "us"
        }
        numlock
    }

    touchpad {
        tap
        natural-scroll
    }

    mouse {
        // accel-profile "flat"
        // accel-speed 0.0
    }

    trackpoint {
        // off
    }

    // warp-mouse-to-focus
    // focus-follows-mouse max-scroll-amount="0%"
}
