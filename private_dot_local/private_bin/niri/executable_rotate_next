#!/bin/bash
# Cycle to the next rotation (90° clockwise each call)
# Usage: rotate_next [output-name]
# Default output: eDP-1

OUTPUT="${1:-eDP-1}"

# Map current transform to an index
CURRENT=$(niri msg outputs 2>/dev/null | awk '/Transform:/ {print $2}')

case "$CURRENT" in
    normal)        NEXT="90"        ;;
    90°)           NEXT="180"       ;;
    180°)          NEXT="270"       ;;
    270°)          NEXT="normal"    ;;
    flipped)       NEXT="flipped-90" ;;
    flipped-90°)   NEXT="flipped-180" ;;
    flipped-180°)  NEXT="flipped-270" ;;
    flipped-270°)  NEXT="flipped"     ;;
    *)             NEXT="normal"     ;;
esac

niri msg output "$OUTPUT" transform "$NEXT"
echo "→ $OUTPUT: $CURRENT → $NEXT"
