#!/bin/bash
# List available outputs and their current rotation
# Usage: rotate_list

echo "=== niri outputs ==="
niri msg outputs 2>/dev/null || echo "(not in a niri session)"

echo ""
echo "=== Available scripts ==="
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
for f in "$SCRIPT_DIR"/rotate_*; do
    name="$(basename "$f")"
    desc="$(head -2 "$f" | tail -1 | sed 's/^# //')"
    printf "  %-20s %s\n" "$name" "$desc"
done
