#!/bin/bash
# Flip the screen horizontally
# Usage: rotate_flip [output-name]
# Default output: eDP-1

OUTPUT="${1:-eDP-1}"

CURRENT=$(niri msg outputs 2>/dev/null | awk '/Transform:/ {print $2}')

case "$CURRENT" in
    normal)        NEXT="flipped"        ;;
    flipped)       NEXT="normal"         ;;
    90°)           NEXT="flipped-90"     ;;
    flipped-90°)   NEXT="90"             ;;
    180°)          NEXT="flipped-180"    ;;
    flipped-180°)  NEXT="180"            ;;
    270°)          NEXT="flipped-270"    ;;
    flipped-270°)  NEXT="270"            ;;
    *)             NEXT="flipped"        ;;
esac

niri msg output "$OUTPUT" transform "$NEXT"
echo "→ $OUTPUT: $CURRENT → $NEXT (flipped)"
