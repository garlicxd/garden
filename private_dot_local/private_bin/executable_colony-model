#!/bin/bash
# Switch llama.cpp server to a different model
# Usage: colony-model [1.5b|12b|27b|35b|32b]

MODELS_DIR="$HOME/models"
SERVICE="llama-server"

declare -A MODELS=(
  ["1.5b"]="$MODELS_DIR/qwen2.5-coder-1.5b.gguf:32768"
  ["12b"]="$MODELS_DIR/gemma4-12b.gguf:65536"
  ["27b"]="$MODELS_DIR/qwen3.6-27b-q4_K_M.gguf:65536"
  ["35b"]="$MODELS_DIR/qwen3.6-35b-a3b-q4_K_M.gguf:65536"
  ["32b"]="$MODELS_DIR/deepseek-r1-32b-qwen-distill-q4_K_M.gguf:65536"
)

list_models() {
  echo "Available models:"
  echo "  1.5b  — Qwen 2.5 Coder 1.5B (autocomplete)"
  echo "  12b   — Gemma 4 12B (quick drafts)"
  echo "  27b   — Qwen3.6 27B (precision refactoring)"
  echo "  35b   — Qwen3.6 35B-A3B (orchestrator) [DEFAULT]"
  echo "  32b   — DeepSeek R1 32B (deep debugging)"
}

if [ -z "$1" ]; then
  list_models
  echo ""
  echo "Usage: colony-model <tag>"
  exit 1
fi

MODEL_ENTRY="${MODELS[$1]}"
if [ -z "$MODEL_ENTRY" ]; then
  echo "Unknown model: $1"
  list_models
  exit 1
fi

MODEL_PATH="${MODEL_ENTRY%%:*}"
CTX_SIZE="${MODEL_ENTRY##*:}"

echo "Switching to: $MODEL_PATH (ctx=$CTX_SIZE)"
systemctl --user stop "$SERVICE" 2>/dev/null
sleep 2

# Override the systemd service temporarily
systemctl --user set-environment LLAMA_MODEL="$MODEL_PATH"
systemctl --user set-environment LLAMA_CTX="$CTX_SIZE"

# If running as a service, restart it. Otherwise start manually.
if systemctl --user is-enabled "$SERVICE" &>/dev/null; then
  systemctl --user start "$SERVICE"
  echo "Service restarted with new model."
else
  # Run directly
  export LD_LIBRARY_PATH="/opt/intel/oneapi/umf/1.1/lib:/opt/intel/oneapi/compiler/2026.0/lib:/opt/intel/oneapi/compiler/2026.0/opt/compiler/lib:/opt/intel/oneapi/mkl/2026.0/lib:$LD_LIBRARY_PATH"
  nohup /home/garlic/llama.cpp/build/bin/llama-server \
    -m "$MODEL_PATH" --host 127.0.0.1 --port 8080 \
    -ngl 99 -c "$CTX_SIZE" --flash-attn on \
    > /tmp/llama-server.log 2>&1 &
  echo "Server started with PID $!"
fi

sleep 5
curl -s http://localhost:8080/health && echo " ✓ Server ready" || echo " ✗ Server failed to start"
