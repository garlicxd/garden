#!/usr/bin/env bash
# npm → bun shim for pi
set -euo pipefail

# Handle npm-specific commands that bun doesn't support natively
case "${1:-}" in
  root)
    # npm root -g → print bun's global node_modules path
    if [ "${2:-}" = "-g" ] || [ "${2:-}" = "--global" ]; then
      bin_dir=$(bun pm bin -g)
      # bun stores globals at <bin_dir>/../install/global/node_modules/
      echo "$(dirname "$bin_dir")/install/global/node_modules"
      exit 0
    fi
    ;;
  pm)
    # npm pm bin -g → bun pm bin -g (already works)
    exec bun "$@"
    ;;
esac

# Build argument list, translating npm commands to bun equivalents
translate=()
has_global=false
install_idx=-1
uninstall_idx=-1

for arg in "$@"; do
  translate+=("$arg")
done

# Detect flags
for arg in "$@"; do
  if [ "$arg" = "-g" ] || [ "$arg" = "--global" ]; then
    has_global=true
  fi
done

# Find command positions
for i in "${!translate[@]}"; do
  case "${translate[$i]}" in
    install) install_idx=$i ;;
    uninstall) uninstall_idx=$i ;;
  esac
done

# Handle: npm uninstall -g <pkg> → bun remove -g <pkg>
if [ "$uninstall_idx" -ge 0 ] && [ "$has_global" = true ]; then
  translate[$uninstall_idx]="remove"
  exec bun "${translate[@]}"
fi

# Handle: npm install <pkg> (local install, no -g)
# --prefix <dir> → bun install --cwd <dir>
# no --prefix     → bun add <pkg>
if [ "$install_idx" -ge 0 ] && [ "$has_global" = false ]; then
  has_pkg_arg=false
  has_prefix=false
  for ((j = install_idx + 1; j < ${#translate[@]}; j++)); do
    candidate="${translate[$j]}"
    if [[ "$candidate" != -* && "$candidate" != "" ]]; then
      has_pkg_arg=true
    fi
    if [ "$candidate" = "--prefix" ] || [ "$candidate" = "--cwd" ]; then
      has_prefix=true
    fi
  done
  if [ "$has_pkg_arg" = true ]; then
    if [ "$has_prefix" = true ]; then
      # Translate to bun install --cwd <dir> ...
      translate[$install_idx]="install"
      for ((j = install_idx + 1; j < ${#translate[@]}; j++)); do
        if [ "${translate[$j]}" = "--prefix" ]; then
          translate[$j]="--cwd"
        fi
      done
    else
      translate[$install_idx]="add"
    fi
    exec bun "${translate[@]}"
  fi
fi

# Default: pass through to bun
exec bun "$@"
