#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='[\u@\h \W]\$ '

export EDITOR="vim"

export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Local scripts (niri helpers, pi launcher)
export PATH="$HOME/.local/bin:$HOME/.local/bin/pi:$PATH"

# Brave browser path for Puppeteer-based tools (marp, etc.)
export CHROME_PATH="/opt/brave-origin-bin/brave"


. "$HOME/.local/bin/env"
