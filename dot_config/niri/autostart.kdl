// ────────────── Startup Applications ──────────────

// Noctalia v5 — native compositor shell
spawn-at-startup "noctalia"

// xdg-desktop-portal (needed for Secret portal / gnome-keyring integration)
spawn-at-startup "start-portal.sh"

// Export env to systemd/dbus so portal services can connect to Wayland
spawn-at-startup "sh" "-c" "dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP"
